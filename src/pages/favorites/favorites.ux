<template>
  <div class="favorites-page">
    <div class="header">
      <div class="back-icon-container" onclick="goBack">
        <text static class="back-icon">←</text>
      </div>
    </div>
    
    <div class="content-container">
      <div class="favorites-list" if="{{ favorites.length > 0 }}">
        <div class="favorite-item" for="{{ favorites }}" onclick="goToDetail($item)">
          <div class="item-content">
            <text class="item-word">{{ $item.word }}</text>
            <text class="item-definition">{{ $item.definition }}</text>
          </div>
        </div>
      </div>
      
      <div class="no-favorites" if="{{ favorites.length === 0 }}">
        <text static class="no-favorites-text">暂无收藏</text>
        <div class="tip-btn" onclick="goBack">
          <text static class="tip-btn-text">去搜索收藏单词</text>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import storage from "../../storage"

export default {
  data: {
    favorites: []
  },

  onInit() {
    console.log('=== 收藏夹页面初始化 ===');
    this.loadFavorites();
  },

  onShow() {
    console.log('=== 收藏夹页面显示 ===');
    this.loadFavorites();
  },

  loadFavorites() {
    console.log('=== 开始异步加载收藏列表 ===');
    
    // 使用异步方式读取收藏数据
    storage.get({
      key: 'favorites',
      success: (data) => {
        console.log('异步读取收藏数据成功:', data);
        
        if (data && data !== '') {
          try {
            this.favorites = JSON.parse(data);
            // 按添加时间倒序排列
            this.favorites.sort((a, b) => b.addedTime - a.addedTime);
            console.log('解析后的收藏列表:', this.favorites);
          } catch (e) {
            console.error('解析收藏数据失败:', e);
            this.favorites = [];
          }
        } else {
          console.log('没有找到收藏数据');
          this.favorites = [];
        }
        
        console.log('最终收藏列表长度:', this.favorites.length);
        console.log('=== 收藏列表加载完成 ===');
      },
      fail: (err) => {
        console.log('异步读取失败，尝试同步方式:', err);
        this.loadFavoritesSync();
      }
    });
  },

  loadFavoritesSync() {
    console.log('同步方式加载收藏列表...');
    try {
      const favoritesData = storage.getSync({
        key: 'favorites',
        default: ''
      });
      console.log('从存储获取的原始数据:', favoritesData);
      
      if (favoritesData && favoritesData !== '') {
        this.favorites = JSON.parse(favoritesData);
        // 按添加时间倒序排列
        this.favorites.sort((a, b) => b.addedTime - a.addedTime);
        console.log('解析后的收藏列表:', this.favorites);
      } else {
        console.log('没有找到收藏数据');
        this.favorites = [];
      }
    } catch (e) {
      console.error('同步加载收藏列表失败:', e);
      this.favorites = [];
    }
    console.log('最终收藏列表长度:', this.favorites.length);
    console.log('=== 收藏列表加载完成 ===');
  },

  

  goToDetail(item) {
    console.log('=== 收藏夹跳转到详情页 ===');
    console.log('单词:', item.word);
    console.log('释义:', item.definition);
    
    // 确保全局变量对象存在
    if (!this.$app.globalData) {
      this.$app.globalData = {};
    }
    
    // 设置全局变量
    this.$app.globalData.word = item.word;
    this.$app.globalData.definition = item.definition || '';
    console.log('已设置全局变量:', this.$app.globalData);
    
    try {
      router.push({
        uri: '/pages/detail',
        params: {
          word: item.word,
          definition: item.definition || ''
        }
      });
      console.log('收藏夹跳转调用成功');
    } catch (error) {
      console.error('收藏夹跳转失败:', error);
    }
    console.log('=== 收藏夹跳转完成 ===');
  },

  goBack() {
    console.log('收藏夹页面返回');
    router.back();
  },

  // 测试方法
  testPage() {
    console.log('=== 收藏夹页面测试 ===');
    console.log('this.favorites:', this.favorites);
    console.log('this.favorites.length:', this.favorites.length);
    console.log('storage available:', typeof storage !== 'undefined');
    console.log('router available:', typeof router !== 'undefined');
    console.log('========================');
  }
}
</script>

