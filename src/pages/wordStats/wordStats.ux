<template>
  <div class="word-stats-page">
    <div class="header">
      <div class="back-icon-container" onclick="goBack">
        <text static class="back-icon">←</text>
      </div>
    </div>
    
    <div class="content-container">
      <div class="stats-list">
        <div class="title-container">
          <text static class="page-title">词库统计</text>
        </div>
        
        <div class="stats-card">
          <text class="stats-label">当前词库</text>
          <div class="stats-main">
            <text class="stat-number">{{ dictionaryCount }}</text>
            <text class="stat-unit">词条</text>
          </div>
        </div>
        
        <div class="stats-card ai-card">
          <text class="stats-label">AI 词库</text>
          <div class="stats-main">
            <text class="stat-number ai-number">{{ aiWordCount }}</text>
            <text class="stat-unit">词条</text>
          </div>
          <text class="ai-note">使用AI总结自动累积</text>
        </div>
        
        <div class="stats-card manual-card">
          <text class="stats-label">手动输入词库</text>
          <div class="stats-main">
            <text class="stat-number manual-number">{{ manualWordCount }}</text>
            <text class="stat-unit">词条</text>
          </div>
          <text class="ai-note">手动添加的单词</text>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import router from "@system.router"
import { dictionary } from "../../common/dictionary"
import storage from "../../storage"

export default {
  data: {
    dictionaryCount: 0,
    aiWordCount: 0,
    manualWordCount: 0
  },

  onInit() {
    console.log('词库统计页面初始化');
    this.calculateWordCount();
    this.loadAIDictionary();
    this.loadManualDictionary();
  },

  onShow() {
    console.log('词库统计页面显示');
    this.calculateWordCount();
    this.loadAIDictionary();
    this.loadManualDictionary();
  },

  calculateWordCount() {
    // 计算当前词库单词总数
    this.dictionaryCount = Object.keys(dictionary).length;
    console.log('词库词条数:', this.dictionaryCount);
  },

  loadAIDictionary() {
    // 从存储中读取 ai_dictionary，统计实际词条数量
    storage.get({
      key: 'ai_dictionary',
      default: '',
      success: (data) => {
        console.log('读取AI词典数据:', data ? '有数据' : '无数据');
        if (data && data !== '') {
          try {
            const aiDictionary = JSON.parse(data);
            this.aiWordCount = Object.keys(aiDictionary).length;
            console.log('AI词库实际词条数:', this.aiWordCount);
          } catch (e) {
            console.error('解析AI词典失败:', e);
            this.aiWordCount = 0;
          }
        } else {
          this.aiWordCount = 0;
          console.log('AI词典为空');
        }
      },
      fail: (err) => {
        console.error('读取AI词典失败:', err);
        this.aiWordCount = 0;
      }
    });
  },

  loadManualDictionary() {
    // 从存储中读取 manual_dictionary，统计实际词条数量
    storage.get({
      key: 'manual_dictionary',
      default: '',
      success: (data) => {
        console.log('读取手动词库数据:', data ? '有数据' : '无数据');
        if (data && data !== '') {
          try {
            const manualDictionary = JSON.parse(data);
            this.manualWordCount = Object.keys(manualDictionary).length;
            console.log('手动词库实际词条数:', this.manualWordCount);
          } catch (e) {
            console.error('解析手动词库失败:', e);
            this.manualWordCount = 0;
          }
        } else {
          this.manualWordCount = 0;
          console.log('手动词库为空');
        }
      },
      fail: (err) => {
        console.error('读取手动词库失败:', err);
        this.manualWordCount = 0;
      }
    });
  },

  goBack() {
    router.back();
  }
}
</script>

