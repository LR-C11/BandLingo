<template>
  <div class="settings-page">
    <div class="header">
      <div class="back-icon-container" onclick="goBack">
        <text static class="back-icon">←</text>
      </div>
    </div>
    
    <scroll class="content-scroll" scroll-y="true">
      <div class="setting-item" onclick="goToAbout">
        <div class="item-content">
          <img src="/common/logo.png" class="app-icon" />
          <div class="item-text">
            <text class="item-title">关于BandLingo</text>
            <text class="item-subtitle">版本 0.1.8 Preview</text>
          </div>
        </div>
        <text static class="arrow-icon">></text>
      </div>

      <div class="setting-item" onclick="goToUIStyle">
        <div class="item-content">
          <img src="/common/uichange.png" class="app-icon" />
          <div class="item-text">
            <text class="item-title">UI样式</text>
            <text class="item-subtitle">{{ uiStyleName }}</text>
          </div>
        </div>
        <text static class="arrow-icon">></text>
      </div>

      <div class="setting-item" onclick="goToWordStats">
        <div class="item-content">
          <img src="/common/word.png" class="app-icon" />
          <div class="item-text">
            <text class="item-title">词库统计</text>
            <text class="item-subtitle">查看词库单词数量</text>
          </div>
        </div>
        <text static class="arrow-icon">></text>
      </div>

      <div class="setting-item" onclick="goToAddWord">
        <div class="item-content">
          <img src="/common/addword.png" class="app-icon" />
          <div class="item-text">
            <text class="item-title">添加单词</text>
            <text class="item-subtitle">手动添加单词到词库</text>
          </div>
        </div>
        <text static class="arrow-icon">></text>
      </div>

      <div class="setting-item" onclick="goToStorage">
        <div class="item-content">
          <img src="/common/storage.png" class="app-icon" />
          <div class="item-text">
            <text class="item-title">存储管理</text>
            <text class="item-subtitle">查看存储使用情况</text>
          </div>
        </div>
        <text static class="arrow-icon">></text>
      </div>

      <div class="setting-item" onclick="goToDonate">
        <div class="item-content">
          <img src="/common/donate.png" class="app-icon" />
          <div class="item-text">
            <text class="item-title">捐赠支持</text>
            <text class="item-subtitle">支持开发者</text>
          </div>
        </div>
        <text static class="arrow-icon">></text>
      </div>

      <div class="footer-space"></div>
    </scroll>
  </div>
</template>

<script>
import router from "@system.router"
import storage from "../../storage"

export default {
  data: {
    settingItems: [],
    uiStyleName: '经典样式'
  },

  onInit() {
    console.log('设定页面初始化');
    this.loadUIStyle();
  },

  onShow() {
    this.loadUIStyle();
  },

  loadUIStyle() {
    storage.get({
      key: 'ui_style',
      default: 'classic',
      success: (data) => {
        const styleNames = {
          'classic': '经典样式',
          'colorful': '彩色小卡片',
          'gradient': '渐变小卡片'
        };
        this.uiStyleName = styleNames[data] || '经典样式';
        console.log('加载UI样式:', this.uiStyleName);
      },
      fail: (err) => {
        console.error('加载UI样式失败:', err);
        this.uiStyleName = '经典样式';
      }
    });
  },

  goBack() {
    router.back();
  },

  goToAbout() {
    router.push({
      uri: '/pages/about'
    });
  },

  goToUIStyle() {
    router.push({
      uri: '/pages/uiStyle'
    });
  },

  goToStorage() {
    router.push({
      uri: '/pages/storage'
    });
  },

  goToWordStats() {
    router.push({
      uri: '/pages/wordStats'
    });
  },

  goToAddWord() {
    router.push({
      uri: '/pages/addWord'
    });
  },

  goToDonate() {
    router.push({
      uri: '/pages/donate'
    });
  }
}
</script>

