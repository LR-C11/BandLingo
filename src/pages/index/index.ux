<import name="inputmethod" src="../../components/InputMethod/InputMethod"></import>

<template>
  <div class="dict-page">
    <div class="content-wrapper" if="{{ !keyboardVisible }}">
      <text static class="page-title">BandLingo</text>
      <div class="input-container" onclick="showKeyboard">
        <text class="input-display {{ searchWord ? 'has-content' : 'placeholder' }}">{{ searchWord || '输入中文或英文单词' }}</text>
      </div>
      <div class="button-row">
        <div class="search-btn" onclick="handleSearch">
          <text static class="search-btn-text">搜索</text>
        </div>
        <div class="favorites-btn" onclick="goToFavorites">
          <text static class="favorites-btn-text">收藏夹</text>
        </div>
      </div>
      <div class="settings-row">
        <div class="settings-btn" onclick="goToSettings">
          <text static class="settings-btn-text">设定</text>
        </div>
      </div>
    </div>
    
    <div class="input-wrapper" if="{{ keyboardVisible }}">
      <div class="input-container-top">
        <text class="input-display-top">{{ searchWord || '输入中文或英文单词...' }}</text>
      </div>
      <div class="search-btn-top" onclick="handleSearch">
        <text static class="search-btn-text-top">搜索</text>
      </div>
      <div class="keyboard-container">
        <inputmethod 
          hide="{{ false }}" 
          maxlength="20"
          onkeydown="handleInputKeyDown"
          oncomplete="handleInputComplete"
          ondelete="handleInputDelete"
          onhide="hideKeyboard"
        ></inputmethod>
      </div>
    </div>
  </div>
</template>

<script>
import router from "@system.router"

export default {
  data: {
    searchWord: "",
    keyboardVisible: false
  },

  onInit() {
    this.searchWord = ""
    this.keyboardVisible = false
  },

  showKeyboard() {
    this.keyboardVisible = true
  },

  hideKeyboard() {
    this.keyboardVisible = false
  },

  handleInputKeyDown(e) {
    const content = e.detail ? e.detail.content : e.content;
    if (content && this.searchWord.length < 20) {
      this.searchWord += content;
    }
  },

  handleInputComplete(e) {
    const content = e.detail ? e.detail.content : e.content;
    if (content && this.searchWord.length < 20) {
      this.searchWord += content;
    }
  },

  handleInputDelete() {
    if (this.searchWord.length > 0) {
      this.searchWord = this.searchWord.slice(0, -1);
    }
  },

  handleSearch() {
    const word = this.searchWord ? this.searchWord.trim() : "";
    console.log('=== 搜索按钮被点击 ===');
    console.log('当前搜索词:', this.searchWord);
    console.log('处理后的搜索词:', word);
    
    if (word) {
      console.log('执行搜索，搜索词:', word);
      try {
        // 根据官方文档，使用以 '/' 开头的应用内页面路径
        router.push({
          uri: '/pages/searchResult',
          params: { 
            word: word 
          }
        });
        console.log('路由跳转调用成功');
      } catch (error) {
        console.error('路由跳转失败:', error);
      }
    } else {
      console.log('搜索词为空，不执行搜索');
    }
  },

  goToFavorites() {
    console.log('=== 开始跳转到收藏夹 ===');
    try {
      router.push({
        uri: '/pages/favorites'
      });
      console.log('收藏夹跳转调用成功');
    } catch (error) {
      console.error('收藏夹跳转失败:', error);
    }
    console.log('=== 收藏夹跳转方法调用完成 ===');
  },



  goToSettings() {
    router.push({
      uri: '/pages/settings'
    });
  },

  onDestroy() {
    // 页面销毁时清理数据，避免内存泄漏
    this.searchWord = "";
    this.keyboardVisible = false;
    // 调用垃圾回收
    if (typeof global !== 'undefined' && global.runGC) {
      global.runGC();
    }
  }
}
</script>

