  font-size: 32px;
  color: #FFFFFF;
  font-weight: bold;
  margin-left: 20px;
}

.content-container {
  width: 100%;
  padding: 8px;
  min-height: 450px;
  justify-content: flex-start;
  align-items: center;
}

.word-detail-card {
  width: 100%;
  max-width: 450px;
  flex-direction: column;
  background-color: #1C1C1E;
  border-radius: 32px;
  padding: 30px;
  border: 1px solid #2C2C2E;
  margin: 0 auto;
}

