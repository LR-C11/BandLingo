}

/* 432*514 设备适配 */
@media (min-width: 432px) and (max-width: 432px) {
  .detail-page {
    width: 432px;
    height: 514px;
  }
  
  .header {
    height: 90px;
    padding: 0 24px;
  }
  
  .back-icon-container {
    width: 140px;
    height: 55px;
    border-radius: 28px;
  }
  
  .back-icon {
    font-size: 34px;
  }
  
  .page-title {
    font-size: 32px;
    margin-left: 20px;
  }
  
  .content-container {
    padding: 8px;
    min-height: 450px;
  }
  
  .word-detail-card {
    max-width: 450px;
    padding: 30px;
    border-radius: 32px;
  }
  
  .word-section {
    margin-bottom: 24px;
