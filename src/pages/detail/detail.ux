  font-weight: bold;
  text-align: center;
  line-height: 40px;
}

.definition-section {
  width: 100%;
  margin-bottom: 30px;
}

.definition-label {
  font-size: 20px;
  color: #8E8E93;
  margin-bottom: 8px;
}

.definition-text {
  font-size: 24px;
  color: #FFFFFF;
  line-height: 30px;
  min-height: 60px;
  max-height: 240px;
  overflow-y: scroll;
  scrollable: true;
}

.word-forms-section {
  width: 100%;
  margin-bottom: 20px;
  padding-left: 16px;
  padding-right: 16px;
}

.word-forms-label-center {
  font-size: 18px;
  color: #8E8E93;
  text-align: center;
  margin-top: 16px;
  margin-bottom: 16px;
  width: 100%;
  flex-direction: row;
  justify-content: center;
}

.word-forms-list {
  width: 100%;
  flex-direction: column;
}

.word-form-item {
  width: 100%;
  min-height: 60px;
  background-color: #2C2C2E;
  border-radius: 10px;
  margin-bottom: 8px;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border: 1px solid #3A3A3C;
}

.word-form-content {
  flex-direction: row;
  align-items: center;
  flex: 1;
}

.word-form-type {
  font-size: 16px;
  color: #8E8E93;
  margin-right: 12px;
  min-width: 40px;
}

.word-form-text {
  font-size: 20px;
  color: #0A84FF;
  font-weight: 500;
}

.word-form-arrow {
  font-size: 18px;
  color: #8E8E93;
  width: 24px;
  text-align: right;
}

.action-section {
  width: 100%;
  flex-direction: row;
  justify-content: center;
  margin-top: 20px;
}

.action-btn {
  width: 160px;
  height: 70px;
  background-color: #48484A;
  border-radius: 35px;
  justify-content: center;
