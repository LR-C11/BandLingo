  }
  
  .word-form-item {
    min-height: 40px;
    margin-bottom: 6px;
    padding: 8px 12px;
    border-radius: 8px;
  }
  
  .word-form-type {
    font-size: 12px;
    margin-bottom: 2px;
  }
  
  .word-form-text {
    font-size: 16px;
  }
  
  .word-form-arrow {
    font-size: 14px;
    width: 16px;
  }
  
  .action-section {
