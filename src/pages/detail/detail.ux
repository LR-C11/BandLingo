<template>
  <div class="detail-page">
    <div class="header">
      <div class="back-icon-container" onclick="goBack">
        <text static class="back-icon">←</text>
      </div>
    </div>
    
    <div class="content-container" style="overflow-y: scroll;">
        <div if="{{ displayWord }}" class="word-detail-card">
          <div class="word-section">
            <text class="word-text">{{ displayWord }}</text>
          </div>
          
          <div class="definition-section">
            <text static class="definition-label">释义</text>
            <text class="definition-text">{{ displayDefinition || '暂无释义' }}</text>
          </div>
          
          <div class="word-forms-section" if="{{ showWordForms }}">
          <div class="word-forms-list">
            <div class="word-form-item" for="{{ wordFormsDataList }}" onclick="goToWordForm($item)">
              <div class="word-form-content">
                <text class="word-form-type">{{ $item.type }}</text>
                <text class="word-form-text">{{ $item.word }}</text>
              </div>
              <text static class="word-form-arrow">→</text>
            </div>
          </div>
        </div>
        
        <div class="action-section">
          <div class="action-btn {{ isFavorited ? 'favorited' : '' }}" onclick="addToFavorites">
            <text static class="action-btn-text">{{ isFavorited ? '已收藏' : '收藏' }}</text>
          </div>
        </div>
        </div>
        
        <div if="{{ !displayWord }}" class="no-data">
          <text static class="no-data-text">未找到单词信息</text>
          <div class="retry-btn" onclick="goBack">
            <text static class="retry-btn-text">返回</text>
          </div>
        </div>
      </div>
  </div>
</template>

<script>
import router from "@system.router"
import storage from "../../storage.js"
import { dictionary } from "../../common/dictionary"
import { wordForms } from "../../common/wordForms"
import { reverseWordForms } from "../../common/reverseWordForms"

export default {
  data: {
    word: "",
    definition: "",
    displayWord: "",
    displayDefinition: "",
    isFavorited: false,
    wordFormsData: null,
    showWordForms: false,
    wordFormsDataList: []
  },

  onInit() {
    console.log('=== WordDetail页面初始化开始 ===');
    console.log('接收到的params:', JSON.stringify(this.params));
    
    // 初始化收藏状态
    this.isFavorited = false;
    
    // 方法1：优先从全局变量获取数据
    if (this.$app && this.$app.globalData && this.$app.globalData.word) {
      this.word = this.$app.globalData.word;
      this.definition = this.$app.globalData.definition || '';
      console.log('从全局变量获取到数据:', { word: this.word, definition: this.definition });
    }
    
    // 方法2：如果全局变量没有数据，从路由参数获取
    if (!this.word && this.params) {
      if (this.params.word) {
        this.word = this.params.word;
        console.log('从params获取到单词:', this.word);
      }
      if (this.params.definition) {
        this.definition = this.params.definition;
        console.log('从params获取到释义:', this.definition);
      }
    }
    
    // 设置显示数据
    this.displayWord = this.word || "";
    this.displayDefinition = this.definition || "";
    
    // 如果没有释义，尝试从字典中获取
    if (this.displayWord && !this.displayDefinition) {
      const wordKey = this.displayWord.toLowerCase();
      if (dictionary[wordKey]) {
        this.displayDefinition = dictionary[wordKey];
        console.log('从字典获取到释义:', this.displayDefinition);
      } else {
        console.log('字典中未找到单词:', this.displayWord);
      }
    }
    
    // 最终检查：如果仍然没有数据，尝试从URI解析
    if (!this.displayWord && this.uri) {
      console.log('尝试从URI解析数据:', this.uri);
      const parsedParams = this.parseUriParams(this.uri);
      if (parsedParams.word) {
        this.displayWord = parsedParams.word;
        console.log('从URI解析到单词:', this.displayWord);
      }
      if (parsedParams.definition) {
        this.displayDefinition = parsedParams.definition;
        console.log('从URI解析到释义:', this.displayDefinition);
      }
    }
    
    console.log('最终显示单词:', this.displayWord);
    console.log('最终显示释义:', this.displayDefinition);
    
    // 立即检查收藏状态和单词形态
    if (this.displayWord) {
      this.checkFavoritedStatus();
      this.checkWordForms();
    }
    
    console.log('=== WordDetail页面初始化完成 ===');
  },

  onShow() {
    console.log('=== WordDetail页面显示 ===');
    
    // 如果当前没有显示数据，尝试重新获取
    if (!this.displayWord) {
      console.log('页面显示时没有数据，尝试重新获取...');
      
      // 尝试从全局变量获取
      if (this.$app && this.$app.globalData && this.$app.globalData.word) {
        this.displayWord = this.$app.globalData.word;
        this.displayDefinition = this.$app.globalData.definition || '';
        console.log('页面显示时从全局变量获取到数据:', { word: this.displayWord, definition: this.displayDefinition });
        
        // 重新检查收藏状态和单词形态
        this.checkFavoritedStatus();
        this.checkWordForms();
      }
    }
    
    console.log('页面显示完成，当前数据:', { word: this.displayWord, definition: this.displayDefinition });
  },

  parseUriParams(uri) {
    const params = {};
    if (!uri) return params;
    
    const queryString = uri.split('?')[1];
    if (!queryString) return params;
    
    const pairs = queryString.split('&');
    for (let i = 0; i < pairs.length; i++) {
      const pair = pairs[i].split('=');
      if (pair.length === 2) {
        params[decodeURIComponent(pair[0])] = decodeURIComponent(pair[1]);
      }
    }
    return params;
  },

  checkFavoritedStatus() {
    console.log('=== 检查收藏状态 ===');
    console.log('要检查的单词:', this.displayWord);
    
    if (!this.displayWord) {
      console.log('没有单词，跳过收藏状态检查');
      return;
    }
    
    // 使用异步方式检查收藏状态
    console.log('异步检查收藏状态...');
    storage.get({
      key: 'favorites',
      default: '',
      success: (data) => {
        console.log('异步读取收藏数据成功:', data);
        let favorites = [];
        if (data && data !== '') {
          try {
            // 检查是否为有效的JSON字符串
            if (data.charAt(0) === '[' || data.charAt(0) === '{') {
              favorites = JSON.parse(data);
            } else {
              console.warn('收藏数据格式不正确，不是JSON格式');
              favorites = [];
            }
          } catch (e) {
            console.error('解析收藏数据失败:', e);
            favorites = [];
          }
        }
        
        const wasFavorited = this.isFavorited;
        this.isFavorited = favorites.some(item => item.word === this.displayWord);
        console.log('收藏状态检查结果:', this.displayWord, '已收藏:', this.isFavorited);
        console.log('之前状态:', wasFavorited, '现在状态:', this.isFavorited);
        console.log('当前收藏列表:', favorites);
        console.log('=== 收藏状态检查完成 ===');
      },
      fail: (err) => {
        console.error('异步读取收藏数据失败:', err);
        this.isFavorited = false;
      }
    });
  },

  goBack() {
    router.back();
  },

  addToFavorites() {
    console.log('收藏按钮被点击了！');
    console.log('=== 开始收藏操作 ===');
    console.log('当前单词:', this.displayWord);
    console.log('当前释义:', this.displayDefinition);
    console.log('当前收藏状态:', this.isFavorited);
    
    if (!this.displayWord) {
      console.log('没有单词，无法收藏');
      return;
    }
    
    // 使用异步方式读取收藏数据
    console.log('异步读取收藏数据...');
    storage.get({
      key: 'favorites',
      default: '',
      success: (data) => {
        console.log('异步读取成功:', data);
        let favoritesList = [];
        if (data && data !== '') {
          try {
            favoritesList = JSON.parse(data);
          } catch (e) {
            console.error('解析数据失败:', e);
            favoritesList = [];
          }
        }
        
        // 执行收藏操作
        const originalState = this.isFavorited;
        console.log('=== 执行收藏操作 ===');
        console.log('当前收藏状态:', originalState);
        console.log('当前单词:', this.displayWord);
        
        if (this.isFavorited) {
          // 取消收藏
          console.log('执行取消收藏操作');
          favoritesList = favoritesList.filter(item => item.word !== this.displayWord);
          this.isFavorited = false;
          console.log('取消收藏成功，新状态:', this.isFavorited);
        } else {
          // 添加收藏
          console.log('执行添加收藏操作');
          // 检查是否已经收藏
          const exists = favoritesList.some(item => item.word === this.displayWord);
          if (!exists) {
            favoritesList.push({
              word: this.displayWord,
              definition: this.displayDefinition,
              addedTime: new Date().getTime()
            });
            this.isFavorited = true;
            console.log('收藏成功，新的收藏列表:', favoritesList);
          } else {
            console.log('该单词已存在于收藏列表中');
            this.isFavorited = true;
          }
        }
        
        console.log('=== 收藏操作完成 ===');
        console.log('状态变化:', originalState, '->', this.isFavorited);
        
        // 异步保存
        let saveData;
        try {
          saveData = JSON.stringify(favoritesList);
          console.log('要保存的数据:', saveData);
        } catch (e) {
          console.error('JSON序列化失败:', e);
          return;
        }
        
        storage.set({
          key: 'favorites',
          value: saveData,
          success: () => {
            console.log('异步保存收藏成功');
            // 强制更新UI以反映收藏状态变化
            this.$forceUpdate && this.$forceUpdate();
          },
          fail: (err) => {
            console.error('异步保存收藏失败:', err);
          }
        });
      },
      fail: (err) => {
        console.error('异步读取收藏数据失败:', err);
        // 使用同步方式处理
        this.performFavoriteSyncAction();
      }
    });
    
    console.log('=== 收藏操作完成 ===');
  },

  performFavoriteSyncAction() {
    console.log('执行同步收藏操作');
    let favorites = [];
    try {
      const favoritesData = storage.getSync({
        key: 'favorites',
        default: ''
      });
      if (favoritesData) {
        favorites = JSON.parse(favoritesData);
      }
    } catch (e) {
      console.error('同步读取失败:', e);
      favorites = [];
    }
    
    // 执行收藏操作
    if (this.isFavorited) {
      // 取消收藏
      console.log('执行同步取消收藏操作');
      favorites = favorites.filter(item => item.word !== this.displayWord);
      this.isFavorited = false;
      console.log('同步取消收藏成功');
    } else {
      // 添加收藏
      console.log('执行同步添加收藏操作');
      const exists = favorites.some(item => item.word === this.displayWord);
      if (!exists) {
        favorites.push({
          word: this.displayWord,
          definition: this.displayDefinition,
          addedTime: new Date().getTime()
        });
        this.isFavorited = true;
        console.log('同步收藏成功');
      } else {
        console.log('该单词已存在于收藏列表中');
        this.isFavorited = true;
      }
    }
    
    // 同步保存
    try {
      storage.setSync({
        key: 'favorites',
        value: JSON.stringify(favorites)
      });
      console.log('同步保存收藏成功');
    } catch (e) {
      console.error('同步保存失败:', e);
    }
    
    // 强制更新UI
    this.$forceUpdate && this.$forceUpdate();
  },

  checkWordForms() {
    if (!this.displayWord) {
      this.showWordForms = false;
      this.wordFormsDataList = [];
      return;
    }
    
    // 获取单词的小写形式
    const wordKey = this.displayWord.toLowerCase();
    
    let wordFormsData = null;
    
    // 首先检查当前单词是否是基础单词
    if (wordForms[wordKey]) {
      wordFormsData = wordForms[wordKey];
    } 
    // 如果不是基础单词，检查是否是某个基础单词的形态
    else if (reverseWordForms[wordKey]) {
      const baseWord = reverseWordForms[wordKey];
      wordFormsData = wordForms[baseWord];
    } 
    // 如果都没有，则没有形态数据
    else {
      this.wordFormsData = null;
      this.showWordForms = false;
      this.wordFormsDataList = [];
      return;
    }
    
    // 设置形态数据
    this.wordFormsData = wordFormsData;
    this.showWordForms = true;
    
    // 转换为数组格式以便渲染
    this.wordFormsDataList = [];
    for (const formType in this.wordFormsData) {
      this.wordFormsDataList.push({
        type: this.getFormTypeLabel(formType),
        word: this.wordFormsData[formType]
      });
    }
  },

  getFormTypeLabel(formType) {
    const typeLabels = {
      'noun': '名词',
      'verb': '动词',
      'adjective': '形容词',
      'adverb': '副词'
    };
    return typeLabels[formType] || formType;
  },

  goToWordForm(item) {
    console.log('=== 跳转到单词形态详情 ===');
    console.log('形态类型:', item.type);
    console.log('目标单词:', item.word);
    
    // 检查目标单词是否在字典中
    const wordKey = item.word.toLowerCase();
    if (dictionary[wordKey]) {
      // 跳转到新的详情页
      router.push({
        uri: '/pages/wordDetail',
        params: {
          word: item.word,
          definition: dictionary[wordKey]
        }
      });
      console.log('跳转到单词形态详情成功');
    } else {
      console.log('目标单词不在字典中:', item.word);
    }
    
    console.log('=== 单词形态跳转完成 ===');
  },

  onDestroy() {
    // 页面销毁时清理数据，避免内存泄漏
    this.displayWord = "";
    this.displayDefinition = "";
  }
}
</script>

