}

.action-btn.favorited {
  background-color: #FFD700;
  border: 1px solid #FFD700;
}

.action-btn-text {
  font-size: 26px;
  color: #FFFFFF;
}

.action-btn.favorited .action-btn-text {
  color: #000000;
}

.no-data {
  width: 100%;
  height: 100%;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.no-data-text {
  font-size: 32px;
  color: #8E8E93;
  margin-bottom: 40px;
}

.retry-btn {
  width: 200px;
  height: 80px;
  border-radius: 40px;
  background-color: #1C1C1E;
  justify-content: center;
  align-items: center;
  border: 1px solid #3A3A3C;
}

.retry-btn-text {
  color: #FFFFFF;
  font-size: 30px;
}

